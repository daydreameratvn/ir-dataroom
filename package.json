{
  "name": "rootstock",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "hasura:start": "cd hasura/ddn && ddn run docker-start",
    "hasura:tunnel": "bun run hasura/scripts/tunnel.ts",
    "hasura:migrate": "bun run hasura/scripts/migrate.ts",
    "hasura:migrate:new": "bun run hasura/scripts/migrate.ts new",
    "hasura:migrate:status": "bun run hasura/scripts/migrate.ts status",
    "hasura:introspect": "cd hasura/ddn && ddn connector introspect banyan_pg",
    "hasura:deploy": "cd hasura/ddn && ddn supergraph build create --apply",
    "hasura:console": "cd hasura/ddn && ddn console",
    "hasura:convert": "bun run hasura/scripts/convert-permissions.ts",
    "hasura:validate": "bun run hasura/scripts/validate-migration.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.997.0",
    "@aws-sdk/client-ecs": "^3.980.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/client-secrets-manager": "^3.997.0",
    "@aws-sdk/client-ssm": "^3.980.0",
    "@pulumi/aws": "^7.19.0",
    "@pulumi/pulumi": "^3.220.0",
    "@pulumi/random": "^4.16.0",
    "jose": "^6.0.0"
  }
}