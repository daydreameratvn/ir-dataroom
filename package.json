{
  "name": "rootstock",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "hasura:start": "cd hasura/ddn && ddn run docker-start",
    "hasura:tunnel": "bun run hasura/scripts/tunnel.ts",
    "hasura:migrate": "bun run hasura/scripts/migrate.ts",
    "hasura:migrate:new": "bun run hasura/scripts/migrate.ts new",
    "hasura:migrate:status": "bun run hasura/scripts/migrate.ts status",
    "hasura:introspect": "cd hasura/ddn && ddn connector introspect banyan_pg",
    "hasura:deploy": "bun run hasura/scripts/deploy.ts",
    "hasura:setup": "bun run hasura/scripts/setup-env.ts",
    "hasura:console": "cd hasura/ddn && ddn console",
    "hasura:convert": "bun run hasura/scripts/convert-permissions.ts",
    "hasura:validate": "bun run hasura/scripts/validate-migration.ts",
    "hasura:schema-check": "bun run hasura/scripts/schema-check.ts",
    "hasura:sync-apple": "cd hasura/ddn && bun run ../scripts/sync-apple.ts",
    "doltgres:tunnel": "bun run hasura/scripts/doltgres-tunnel.ts",
    "doltgres:init-schema": "bun run hasura/scripts/doltgres-init-schema.ts",
    "dev": "bash scripts/dev.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
