{
  "name": "@papaya/phoenix-react",
  "version": "0.0.1",
  "description": "Phoenix Claims Portal React SDK — embeddable portal component for partners",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "registry": "https://papaya-812652266901.d.codeartifact.ap-southeast-1.amazonaws.com/npm/sdks/"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@papaya/phoenix": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
