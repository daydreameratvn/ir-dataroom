kind: AuthConfig
version: v2
definition:
  mode:
    jwt:
      claimsConfig:
        namespace:
          claimsFormat: Json
          location: "/https:~1~1hasura.io~1jwt~1claims"
      key:
        fixed:
          algorithm: HS256
          key:
            valueFromEnv: JWT_SECRET_KEY
      tokenLocation:
        type: BearerAuthorization
