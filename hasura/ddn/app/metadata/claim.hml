      type: Uuid
    - name: adjudicated_at
      type: Timestamptz
    - name: denial_reason
      type: String
    - name: ai_recommendation
      type: String
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: claims
      fieldMapping:
        id:
          column:
            name: id
        created_at:
          column:
            name: created_at
        created_by:
          column:
            name: created_by
        updated_at:
          column:
            name: updated_at
        updated_by:
          column:
            name: updated_by
        deleted_at:
          column:
            name: deleted_at
        tenant_id:
          column:
            name: tenant_id
        claim_number:
          column:
            name: claim_number
        status:
          column:
            name: status
        policy_id:
          column:
            name: policy_id
        claimant_name:
          column:
