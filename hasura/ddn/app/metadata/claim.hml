  graphql:
    typeName: Claim
---
kind: Model
version: v2
definition:
  name: Claims
  objectType: Claim
  source:
    dataConnectorName: banyan_pg
    collection: claims
  graphql:
    selectMany:
      queryRootField: claims
    selectUniques:
      - queryRootField: claimById
        uniqueIdentifier: [id]
---
kind: ModelPermissions
version: v1
definition:
  modelName: Claims
  permissions:
    - role: admin
      select:
        filter: null
---
kind: TypePermissions
version: v1
definition:
  typeName: Claim
  permissions:
    - role: admin
      output:
        allowedFields:
          - id
          - created_at
          - created_by
          - updated_at
          - updated_by
          - deleted_at
          - tenant_id
          - claim_number
          - status
          - policy_id
          - claimant_name
          - provider_id
          - provider_name
          - amount_claimed
          - amount_approved
          - currency
          - date_of_loss
          - date_of_service
          - submitted_by
          - assigned_to
          - ai_summary
          - ai_score
          - amount_paid
          - adjudicated_by
          - adjudicated_at
          - denial_reason
          - ai_recommendation
