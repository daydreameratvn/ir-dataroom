  name: UserLevels
  objectType: UserLevel
  source:
    dataConnectorName: banyan_pg
    collection: user_levels
  graphql:
    selectMany:
      queryRootField: userLevels
    selectUniques:
      - queryRootField: userLevelByValue
        uniqueIdentifier: [value]
---
kind: ModelPermissions
