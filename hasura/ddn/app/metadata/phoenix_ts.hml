kind: DataConnectorLink
version: v1
definition:
  name: phoenix_ts
  url:
    singleUrl:
      valueFromEnv: APP_PHOENIX_TS_READ_URL
  headers:
    Authorization:
      valueFromEnv: APP_PHOENIX_TS_AUTHORIZATION_HEADER
  schema:
    version: v0.2
    schema:
      collections: []
      functions: []
      object_types:
        ClaimDocumentInfo:
          fields:
            claimId:
              type:
                name: String
                type: named
            createdAt:
              type:
                name: String
                type: named
            documentType:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
            fileName:
              type:
                name: String
                type: named
            fileSizeBytes:
              type:
                type: nullable
                underlying_type:
                  name: Float
                  type: named
            fileType:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
            fileUrl:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
            id:
              type:
                name: String
                type: named
          foreign_keys: {}
        LoginResultItem:
          fields:
            message:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
            policy:
              type:
                type: nullable
                underlying_type:
                  name: PolicyInfo
                  type: named
            policyNumber:
              type:
                name: String
                type: named
            success:
              type:
                name: Boolean
                type: named
            token:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
          foreign_keys: {}
        PhoenixLoginResponse:
          fields:
            results:
              type:
                element_type:
                  name: LoginResultItem
                  type: named
                type: array
          foreign_keys: {}
        PhoenixOtpResponse:
          fields:
            success:
              type:
                name: Boolean
                type: named
          foreign_keys: {}
        PhoenixRefreshTokenResponse:
          fields:
            token:
              type:
                name: String
                type: named
          foreign_keys: {}
        PhoenixUploadDocumentResponse:
          fields:
            document:
              type:
                name: ClaimDocumentInfo
                type: named
            uploadUrl:
              type:
                name: String
                type: named
          foreign_keys: {}
        PhoenixVerifyOtpResponse:
          fields:
            success:
              type:
                name: Boolean
                type: named
            verified:
              type:
                name: Boolean
                type: named
          foreign_keys: {}
        PolicyInfo:
          fields:
            id:
              type:
                name: String
                type: named
            insuredName:
              type:
                name: String
                type: named
            policyNumber:
              type:
                name: String
                type: named
            status:
              type:
                name: String
                type: named
          foreign_keys: {}
      procedures:
        - arguments:
            policyNumbers:
              type:
                element_type:
                  name: String
                  type: named
                type: array
          description: |-
            Authenticate policy holders by policy numbers.
            Returns JWT tokens for each valid policy.
          name: phoenixLogin
          result_type:
            name: PhoenixLoginResponse
            type: named
        - arguments:
            token:
              type:
                name: String
                type: named
          description: |-
            Refresh an expired Phoenix JWT token.
            Requires a valid (or recently expired) token in the session.
          name: phoenixRefreshToken
          result_type:
            name: PhoenixRefreshTokenResponse
            type: named
        - arguments:
            claimId:
              type:
                name: String
                type: named
            token:
              type:
                name: String
                type: named
          description: |-
            Request an OTP code for claim verification.
            Sends the code to the insured person's registered email/phone.
          name: phoenixRequestOtp
          result_type:
            name: PhoenixOtpResponse
            type: named
        - arguments:
            claimId:
              type:
                name: String
                type: named
            code:
              type:
                name: String
                type: named
            token:
              type:
                name: String
                type: named
          description: Verify an OTP code for claim action authorization.
          name: phoenixVerifyOtp
          result_type:
            name: PhoenixVerifyOtpResponse
            type: named
        - arguments:
            claimId:
              type:
                name: String
                type: named
            documentType:
              type:
                type: nullable
                underlying_type:
                  name: String
                  type: named
            fileName:
              type:
                name: String
                type: named
            fileType:
              type:
                name: String
                type: named
            token:
              type:
                name: String
                type: named
          description: |-
            Request a presigned S3 upload URL for a claim document.
            Returns the upload URL and the created document record.
          name: phoenixUploadDocument
          result_type:
            name: PhoenixUploadDocumentResponse
            type: named
      scalar_types:
        Boolean:
          aggregate_functions: {}
          comparison_operators:
            _eq:
              type: equal
          representation:
            type: boolean
        Float:
          aggregate_functions: {}
          comparison_operators:
            _eq:
              type: equal
          representation:
            type: float64
        String:
          aggregate_functions: {}
          comparison_operators:
            _eq:
              type: equal
          representation:
            type: string
    capabilities:
      capabilities:
        mutation: {}
        query:
          nested_fields: {}
          variables: {}
      version: 0.2.0
