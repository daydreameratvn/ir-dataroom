---
kind: Model
version: v2
definition:
  name: Providers
  objectType: Provider
  source:
    dataConnectorName: banyan_pg
    collection: providers
  graphql:
    selectMany:
      queryRootField: providers
    selectUniques:
      - queryRootField: providerById
        uniqueIdentifier: [id]
