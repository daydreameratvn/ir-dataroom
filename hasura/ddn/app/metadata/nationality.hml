---
kind: ObjectType
version: v1
definition:
  name: Nationality
  fields:
    - name: value
      type: String!
    - name: comment
      type: String
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: nationalities
      fieldMapping:
        value:
          column:
            name: value
        comment:
          column:
            name: comment
  graphql:
    typeName: Nationality
---
kind: Model
version: v2
definition:
  name: Nationalities
  objectType: Nationality
  source:
    dataConnectorName: banyan_pg
    collection: nationalities
  graphql:
    selectMany:
      queryRootField: nationalities
    selectUniques:
      - queryRootField: nationalityByValue
        uniqueIdentifier: [value]
---
kind: ModelPermissions
version: v1
definition:
  modelName: Nationalities
  permissions:
    - role: admin
      select:
        filter: null
---
kind: TypePermissions
version: v1
definition:
  typeName: Nationality
  permissions:
    - role: admin
      output:
        allowedFields: [value, comment]
---
kind: Relationship
version: v1
definition:
  name: tenants
  sourceType: Nationality
  target:
    model:
      name: Tenants
      relationshipType: Array
  mapping:
    - source:
        fieldPath:
          - fieldName: value
      target:
        modelField:
          - fieldName: national
---
kind: Relationship
version: v1
definition:
  name: providers
  sourceType: Nationality
  target:
    model:
      name: Providers
      relationshipType: Array
  mapping:
    - source:
        fieldPath:
          - fieldName: value
      target:
        modelField:
          - fieldName: country
