---
kind: ObjectType
version: v1
definition:
  name: EndorsementType
  fields:
    - name: value
      type: String!
    - name: comment
      type: String
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: endorsement_types
      fieldMapping:
        value:
          column:
            name: value
        comment:
          column:
            name: comment
  graphql:
    typeName: EndorsementType
---
kind: Model
version: v2
definition:
  name: EndorsementTypes
  objectType: EndorsementType
  source:
    dataConnectorName: banyan_pg
    collection: endorsement_types
  graphql:
    selectMany:
      queryRootField: endorsementTypes
    selectUniques:
      - queryRootField: endorsementTypeByValue
        uniqueIdentifier: [value]
---
kind: ModelPermissions
version: v1
definition:
  modelName: EndorsementTypes
  permissions:
    - role: admin
      select:
        filter: null
---
kind: TypePermissions
version: v1
definition:
  typeName: EndorsementType
  permissions:
    - role: admin
      output:
        allowedFields: [value, comment]
---
kind: Relationship
version: v1
definition:
  name: endorsements
  sourceType: EndorsementType
  target:
    model:
      name: Endorsements
      relationshipType: Array
  mapping:
    - source:
        fieldPath:
          - fieldName: value
      target:
        modelField:
          - fieldName: endorsement_type
