            name: department
        locale:
          column:
            name: locale
        last_login_at:
          column:
            name: last_login_at
        phone:
          column:
            name: phone
  graphql:
    typeName: User
---
kind: Model
version: v2
definition:
  name: Users
  objectType: User
  source:
    dataConnectorName: banyan_pg
    collection: users
  graphql:
    selectMany:
      queryRootField: users
    selectUniques:
      - queryRootField: userById
        uniqueIdentifier: [id]
---
kind: ModelPermissions
version: v1
definition:
  modelName: Users
  permissions:
    - role: admin
      select:
        filter: null
---
kind: TypePermissions
version: v1
definition:
  typeName: User
  permissions:
    - role: admin
      output:
        allowedFields:
          - id
          - created_at
          - created_by
          - updated_at
          - updated_by
          - deleted_at
          - tenant_id
          - email
          - name
          - avatar_url
          - user_type
          - user_level
          - title
          - department
          - locale
          - last_login_at
          - phone
