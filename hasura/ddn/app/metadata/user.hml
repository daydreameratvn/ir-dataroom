      type: String
    - name: user_type
      type: String!
    - name: user_level
      type: String!
    - name: title
      type: String
    - name: department
      type: String
    - name: locale
      type: String
    - name: last_login_at
      type: Timestamptz
    - name: phone
      type: String
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: users
      fieldMapping:
        id:
          column:
            name: id
        created_at:
          column:
            name: created_at
        created_by:
          column:
            name: created_by
        updated_at:
          column:
            name: updated_at
        updated_by:
          column:
            name: updated_by
        deleted_at:
          column:
            name: deleted_at
        tenant_id:
          column:
