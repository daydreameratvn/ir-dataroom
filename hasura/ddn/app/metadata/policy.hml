---
kind: Model
version: v2
definition:
  name: Policies
  objectType: Policy
  source:
    dataConnectorName: banyan_pg
    collection: policies
  graphql:
    selectMany:
      queryRootField: policies
    selectUniques:
      - queryRootField: policyById
        uniqueIdentifier: [id]
---
kind: ModelPermissions
version: v1
definition:
