---
kind: ObjectType
version: v1
definition:
  name: ClaimDocument
  fields:
    - name: id
      type: Uuid!
    - name: created_at
      type: Timestamptz!
    - name: created_by
      type: Uuid
    - name: updated_at
      type: Timestamptz!
    - name: updated_by
      type: Uuid
    - name: deleted_at
      type: Timestamptz
    - name: claim_id
      type: Uuid!
    - name: tenant_id
      type: Uuid!
    - name: file_name
      type: String!
    - name: file_type
      type: String
    - name: file_url
      type: String!
    - name: file_size_bytes
      type: Int8
    - name: document_type
      type: String
    - name: uploaded_by
      type: Uuid
    - name: extracted_text
      type: String
    - name: extracted_amount
      type: Numeric
    - name: extracted_date
      type: Timestamptz
    - name: extraction_confidence
      type: Numeric
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: claim_documents
      fieldMapping:
        id:
          column:
            name: id
        created_at:
          column:
            name: created_at
        created_by:
          column:
            name: created_by
        updated_at:
          column:
            name: updated_at
        updated_by:
          column:
            name: updated_by
        deleted_at:
          column:
            name: deleted_at
        claim_id:
          column:
            name: claim_id
        tenant_id:
          column:
            name: tenant_id
        file_name:
          column:
            name: file_name
        file_type:
          column:
            name: file_type
        file_url:
          column:
            name: file_url
        file_size_bytes:
          column:
            name: file_size_bytes
        document_type:
          column:
            name: document_type
        uploaded_by:
          column:
            name: uploaded_by
        extracted_text:
          column:
            name: extracted_text
        extracted_amount:
          column:
            name: extracted_amount
        extracted_date:
          column:
            name: extracted_date
        extraction_confidence:
          column:
            name: extraction_confidence
  graphql:
    typeName: ClaimDocument
---
kind: Model
version: v2
definition:
  name: ClaimDocuments
  objectType: ClaimDocument
  source:
    dataConnectorName: banyan_pg
    collection: claim_documents
  graphql:
    selectMany:
      queryRootField: claimDocuments
    selectUniques:
      - queryRootField: claimDocumentById
        uniqueIdentifier: [id]
---
kind: ModelPermissions
version: v1
definition:
  modelName: ClaimDocuments
  permissions:
    - role: admin
      select:
        filter: null
---
kind: TypePermissions
version: v1
definition:
  typeName: ClaimDocument
  permissions:
    - role: admin
      output:
        allowedFields:
          - id
          - created_at
          - created_by
          - updated_at
          - updated_by
          - deleted_at
          - claim_id
          - tenant_id
          - file_name
          - file_type
          - file_url
          - file_size_bytes
          - document_type
          - uploaded_by
          - extracted_text
          - extracted_amount
          - extracted_date
          - extraction_confidence
---
kind: Relationship
version: v1
definition:
  name: claim
  sourceType: ClaimDocument
  target:
    model:
      name: Claims
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: claim_id
      target:
        modelField:
          - fieldName: id
---
kind: Relationship
version: v1
definition:
  name: tenant
  sourceType: ClaimDocument
  target:
    model:
      name: Tenants
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: tenant_id
      target:
        modelField:
          - fieldName: id
---
kind: Relationship
version: v1
definition:
  name: uploadedByUser
  sourceType: ClaimDocument
  target:
    model:
      name: Users
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: uploaded_by
      target:
        modelField:
          - fieldName: id
