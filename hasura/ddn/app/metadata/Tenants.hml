---
kind: ObjectType
version: v1
definition:
  name: Tenants
  fields:
    - name: configuration
      type: Json
    - name: createdAt
      type: Timestamptz!
    - name: deletedAt
      type: Timestamptz
    - name: id
      type: Uuid!
    - name: name
      type: String_1!
    - name: national
      type: String_1
    - name: updatedAt
      type: Timestamptz!
  graphql:
    typeName: Tenants
    inputTypeName: TenantsInput
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: tenants
      fieldMapping:
        configuration:
          column:
            name: configuration
        createdAt:
          column:
            name: created_at
        deletedAt:
          column:
            name: deleted_at
        id:
          column:
            name: id
        name:
          column:
            name: name
        national:
          column:
            name: national
        updatedAt:
          column:
            name: updated_at

---
kind: TypePermissions
version: v1
definition:
  typeName: Tenants
  permissions:
    - role: admin
      output:
        allowedFields:
          - configuration
          - createdAt
          - deletedAt
          - id
          - name
          - national
          - updatedAt

---
kind: AggregateExpression
version: v1
definition:
  name: TenantsAggExp
  operand:
    object:
      aggregatedType: Tenants
      aggregatableFields:
        - fieldName: configuration
          aggregateExpression: JsonbAggExp
        - fieldName: createdAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: deletedAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: id
          aggregateExpression: UuidAggExp
        - fieldName: name
          aggregateExpression: TextAggExp
        - fieldName: national
          aggregateExpression: TextAggExp
        - fieldName: updatedAt
          aggregateExpression: TimestamptzAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: TenantsAggExp

---
kind: Model
version: v2
definition:
  name: Tenants
  objectType: Tenants
  source:
    dataConnectorName: banyan_pg
    collection: tenants
  filterExpressionType: TenantsBoolExp
  aggregateExpression: TenantsAggExp
  orderByExpression: TenantsOrderByExp
  graphql:
    selectMany:
      queryRootField: tenants
      subscription:
        rootField: tenants
    selectUniques:
      - queryRootField: tenantsById
        uniqueIdentifier:
          - id
        subscription:
          rootField: tenantsById
    filterInputTypeName: TenantsFilterInput
    aggregate:
      queryRootField: tenantsAggregate
      subscription:
        rootField: tenantsAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: Tenants
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

