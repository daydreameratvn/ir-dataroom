---
kind: BooleanExpressionType
version: v1
definition:
  name: TenantsBoolExp
  operand:
    object:
      type: Tenants
      comparableFields:
        - fieldName: configuration
          booleanExpressionType: JsonbBoolExp
        - fieldName: createdAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: deletedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: id
          booleanExpressionType: UuidBoolExp
        - fieldName: name
          booleanExpressionType: TextBoolExp
        - fieldName: national
          booleanExpressionType: TextBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
      comparableRelationships:
        - relationshipName: agentActions
        - relationshipName: agentSessions
        - relationshipName: auditLogEntries
        - relationshipName: auditLogs
        - relationshipName: authIdentities
        - relationshipName: authLoginAttempts
        - relationshipName: authOtpRequests
        - relationshipName: authPasskeys
        - relationshipName: authSessions
        - relationshipName: claimDiagnoses
        - relationshipName: claimDocuments
        - relationshipName: claimNotes
        - relationshipName: claimProcedures
        - relationshipName: claims
        - relationshipName: endorsements
        - relationshipName: fwaAlerts
        - relationshipName: fwaRules
        - relationshipName: policies
        - relationshipName: products
        - relationshipName: providerContracts
        - relationshipName: providers
        - relationshipName: nationality
        - relationshipName: users
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: TenantsBoolExp

