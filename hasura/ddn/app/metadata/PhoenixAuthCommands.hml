  typeName: PhoenixRefreshTokenResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - token
    - role: policyholder
      output:
        allowedFields:
          - token

---
kind: ObjectType
version: v1
definition:
  name: PhoenixOtpResponse
  fields:
    - name: success
      type: Boolean!
  graphql:
    typeName: PhoenixOtpResponse
    inputTypeName: PhoenixOtpResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: phoenix_ts
