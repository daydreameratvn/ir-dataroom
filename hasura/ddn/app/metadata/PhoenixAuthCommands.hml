# Phoenix Auth Commands
#
# GraphQL mutations that proxy authentication operations to the auth service
# via the phoenix_ts TypeScript Lambda connector.
#
# These commands match the Phoenix SDK's expected GraphQL API:
#   phoenixLogin, phoenixRefreshToken, phoenixRequestOtp,
#   phoenixVerifyOtp, phoenixUploadDocument

# ═══════════════════════════════════════════════════════════════════════════════
# Object Types (output types for Phoenix responses)
# ═══════════════════════════════════════════════════════════════════════════════

---
kind: ObjectType
version: v1
definition:
  name: PhoenixPolicyInfo
  fields:
    - name: id
      type: String!
    - name: policyNumber
      type: String!
    - name: insuredName
      type: String!
    - name: status
      type: String!
  graphql:
    typeName: PhoenixPolicyInfo
    inputTypeName: PhoenixPolicyInfoInput
  dataConnectorTypeMapping:
    - dataConnectorName: phoenix_ts
      dataConnectorObjectType: PolicyInfo
      fieldMapping:
        id:
          column:
            name: id
        policyNumber:
          column:
            name: policyNumber
        insuredName:
          column:
            name: insuredName
        status:
          column:
            name: status

---
kind: TypePermissions
version: v1
definition:
  typeName: PhoenixPolicyInfo
  permissions:
    - role: admin
      output:
        allowedFields:
          - id
          - policyNumber
          - insuredName
          - status
    - role: policyholder
      output:
        allowedFields:
          - id
          - policyNumber
          - insuredName
          - status

---
kind: ObjectType
version: v1
definition:
  name: PhoenixLoginResultItem
  fields:
    - name: policyNumber
      type: String!
    - name: success
      type: Boolean!
    - name: message
      type: String
    - name: token
      type: String
    - name: policy
      type: PhoenixPolicyInfo
  graphql:
    typeName: PhoenixLoginResultItem
    inputTypeName: PhoenixLoginResultItemInput
  dataConnectorTypeMapping:
    - dataConnectorName: phoenix_ts
      dataConnectorObjectType: LoginResultItem
      fieldMapping:
        policyNumber:
          column:
            name: policyNumber
        success:
          column:
            name: success
        message:
          column:
            name: message
        token:
          column:
            name: token
        policy:
          column:
            name: policy

---
kind: TypePermissions
version: v1
definition:
  typeName: PhoenixLoginResultItem
  permissions:
    - role: admin
      output:
        allowedFields:
          - policyNumber
          - success
          - message
          - token
          - policy
    - role: policyholder
      output:
        allowedFields:
          - policyNumber
          - success
          - message
          - token
          - policy

---
kind: ObjectType
version: v1
definition:
  name: PhoenixLoginResponse
  fields:
    - name: results
      type: "[PhoenixLoginResultItem!]!"
  graphql:
    typeName: PhoenixLoginResponse
    inputTypeName: PhoenixLoginResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: phoenix_ts
      dataConnectorObjectType: PhoenixLoginResponse
      fieldMapping:
        results:
          column:
            name: results

---
kind: TypePermissions
version: v1
definition:
  typeName: PhoenixLoginResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - results
    - role: policyholder
      output:
        allowedFields:
          - results

---
kind: ObjectType
version: v1
definition:
  name: PhoenixRefreshTokenResponse
  fields:
    - name: token
      type: String!
  graphql:
    typeName: PhoenixRefreshTokenResponse
    inputTypeName: PhoenixRefreshTokenResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: phoenix_ts
      dataConnectorObjectType: PhoenixRefreshTokenResponse
      fieldMapping:
        token:
