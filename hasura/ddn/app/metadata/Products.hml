      type: Bigdecimal
    - name: maxPremium
      type: Bigdecimal
    - name: minPremium
      type: Bigdecimal
    - name: name
      type: String_1!
    - name: productLine
      type: String_1
    - name: tenantId
      type: Uuid!
    - name: updatedAt
      type: Timestamptz!
    - name: updatedBy
      type: Uuid
    - name: waitingPeriodDays
      type: Int32
  graphql:
    typeName: Products
    inputTypeName: ProductsInput
  dataConnectorTypeMapping:
    - dataConnectorName: banyan_pg
      dataConnectorObjectType: products
      fieldMapping:
        active:
          column:
            name: active
        code:
          column:
            name: code
        coverageTermMonths:
          column:
            name: coverage_term_months
        createdAt:
          column:
            name: created_at
