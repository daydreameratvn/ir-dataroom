---
kind: ObjectType
version: v1
definition:
  name: PolicyDocuments
  fields:
    - name: createdAt
      type: Timestamptz!
    - name: deletedAt
      type: Timestamp
    - name: id
      type: Uuid
    - name: policyDocumentId
      type: Uuid!
    - name: policyId
      type: Uuid!
    - name: tenantId
      type: Uuid!
    - name: type
      type: String_1
    - name: updatedAt
      type: Timestamptz!
  graphql:
    typeName: PolicyDocuments
    inputTypeName: PolicyDocumentsInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: policy_documents
      fieldMapping:
        createdAt:
          column:
            name: created_at
        deletedAt:
          column:
            name: deleted_at
        id:
          column:
            name: id
        policyDocumentId:
          column:
            name: policy_document_id
        policyId:
          column:
            name: policy_id
        tenantId:
          column:
            name: tenant_id
        type:
          column:
            name: type
        updatedAt:
          column:
            name: updated_at

---
kind: TypePermissions
version: v1
definition:
  typeName: PolicyDocuments
  permissions:
