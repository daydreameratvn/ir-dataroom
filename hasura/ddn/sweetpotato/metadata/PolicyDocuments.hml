  graphql:
    expressionTypeName: PolicyDocumentsOrderByExp

---
kind: Model
version: v2
definition:
  name: PolicyDocuments
  objectType: PolicyDocuments
  source:
    dataConnectorName: sweetpotato_pg
    collection: policy_documents
  filterExpressionType: PolicyDocumentsBoolExp
  aggregateExpression: PolicyDocumentsAggExp
  orderByExpression: PolicyDocumentsOrderByExp
  graphql:
    selectMany:
      queryRootField: policyDocuments
      subscription:
        rootField: policyDocuments
    selectUniques:
      - queryRootField: policyDocumentsByPolicyDocumentId
        uniqueIdentifier:
          - policyDocumentId
        subscription:
          rootField: policyDocumentsByPolicyDocumentId
    filterInputTypeName: PolicyDocumentsFilterInput
    aggregate:
      queryRootField: policyDocumentsAggregate
      subscription:
        rootField: policyDocumentsAggregate

