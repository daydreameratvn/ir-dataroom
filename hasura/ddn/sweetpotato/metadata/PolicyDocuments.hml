        allowedFields:
          - createdAt
          - deletedAt
          - id
          - policyDocumentId
          - policyId
          - tenantId
          - type
          - updatedAt

---
kind: BooleanExpressionType
version: v1
definition:
  name: PolicyDocumentsBoolExp
  operand:
    object:
      type: PolicyDocuments
      comparableFields:
        - fieldName: createdAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: deletedAt
          booleanExpressionType: TimestampBoolExp
        - fieldName: id
          booleanExpressionType: UuidBoolExp
        - fieldName: policyDocumentId
          booleanExpressionType: UuidBoolExp
        - fieldName: policyId
          booleanExpressionType: UuidBoolExp
        - fieldName: tenantId
          booleanExpressionType: UuidBoolExp
        - fieldName: type
          booleanExpressionType: TextBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
      comparableRelationships:
        - relationshipName: files
        - relationshipName: policy
        - relationshipName: tenant
        - relationshipName: policyDocumentType
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: PolicyDocumentsBoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: PolicyDocumentsAggExp
  operand:
    object:
      aggregatedType: PolicyDocuments
      aggregatableFields:
        - fieldName: createdAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: deletedAt
