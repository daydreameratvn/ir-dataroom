kind: Relationship
version: v1
definition:
  name: bankBranchs
  sourceType: Banks
  target:
    model:
      name: BankBranchs
      relationshipType: Array
      aggregate:
        aggregateExpression: BankBranchsAggExp
  mapping:
    - source:
        fieldPath:
          - fieldName: id
      target:
        modelField:
