---
kind: Model
version: v2
definition:
  name: HawthornPatients
  objectType: HawthornPatients
  source:
    dataConnectorName: sweetpotato_pg
    collection: hawthorn_patients
  filterExpressionType: HawthornPatientsBoolExp
  aggregateExpression: HawthornPatientsAggExp
  orderByExpression: HawthornPatientsOrderByExp
  graphql:
    selectMany:
      queryRootField: hawthornPatients
      subscription:
        rootField: hawthornPatients
    selectUniques:
      - queryRootField: hawthornPatientsByPatientsFullNameDobGenderKey
        uniqueIdentifier:
          - dob
          - fullName
          - gender
        subscription:
          rootField: hawthornPatientsByPatientsFullNameDobGenderKey
      - queryRootField: hawthornPatientsById
        uniqueIdentifier:
          - id
        subscription:
          rootField: hawthornPatientsById
    filterInputTypeName: HawthornPatientsFilterInput
    aggregate:
      queryRootField: hawthornPatientsAggregate
      subscription:
        rootField: hawthornPatientsAggregate

