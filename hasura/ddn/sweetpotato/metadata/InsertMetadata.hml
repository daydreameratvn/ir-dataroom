---
kind: ObjectType
version: v1
definition:
  name: InsertMetadataObject
  fields:
    - name: createdAt
      type: Timestamptz
    - name: deletedAt
      type: Timestamptz
    - name: description
      type: String_1
    - name: locale
      type: String_1!
    - name: metadataId
      type: Uuid
    - name: title
      type: String_1!
    - name: type
      type: String_1!
    - name: updatedAt
      type: Timestamptz
    - name: value
      type: String_1!
  graphql:
    typeName: InsertMetadataObject
    inputTypeName: InsertMetadataObjectInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: insert_metadata_object
      fieldMapping:
        createdAt:
          column:
            name: created_at
        deletedAt:
          column:
            name: deleted_at
        description:
          column:
            name: description
        locale:
          column:
            name: locale
        metadataId:
          column:
            name: metadata_id
        title:
          column:
            name: title
        type:
          column:
            name: type
        updatedAt:
          column:
            name: updated_at
        value:
          column:
            name: value

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertMetadataObject
  permissions:
    - role: admin
      output:
        allowedFields:
          - createdAt
          - deletedAt
          - description
          - locale
          - metadataId
          - title
          - type
          - updatedAt
          - value

---
kind: ObjectType
version: v1
definition:
  name: InsertMetadataResponse
  description: Responses from the 'insert_metadata' procedure
  fields:
    - name: affectedRows
      type: Int32!
      description: The number of rows affected by the mutation
    - name: returning
      type: "[Metadata!]!"
      description: Data from rows affected by the mutation
  graphql:
    typeName: InsertMetadataResponse
    inputTypeName: InsertMetadataResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: insert_metadata_response
      fieldMapping:
        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertMetadataResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

---
kind: Command
version: v1
definition:
  name: InsertMetadata
  outputType: InsertMetadataResponse!
  arguments:
    - name: objects
      type: "[InsertMetadataObject!]!"
    - name: postCheck
      type: MetadataBoolExp
      description: Insert permission predicate over the 'metadata' collection
  source:
    dataConnectorName: sweetpotato_pg
    dataConnectorCommand:
      procedure: insert_metadata
    argumentMapping:
      objects: objects
      postCheck: post_check
  graphql:
    rootFieldName: insertMetadata
    rootFieldKind: Mutation
  description: Insert into the metadata table

---
kind: CommandPermissions
version: v1
definition:
  commandName: InsertMetadata
  permissions:
    - role: admin
      allowExecution: true

