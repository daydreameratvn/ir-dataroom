---
kind: Model
version: v2
definition:
  name: Drugs
  objectType: Drugs
  source:
    dataConnectorName: sweetpotato_pg
    collection: drugs
  filterExpressionType: DrugsBoolExp
  aggregateExpression: DrugsAggExp
  orderByExpression: DrugsOrderByExp
  graphql:
    selectMany:
      queryRootField: drugs
      subscription:
        rootField: drugs
    selectUniques:
      - queryRootField: drugsById
        uniqueIdentifier:
          - id
        subscription:
          rootField: drugsById
      - queryRootField: drugsByRegistrationCode
        uniqueIdentifier:
          - registrationCode
        subscription:
          rootField: drugsByRegistrationCode
    filterInputTypeName: DrugsFilterInput
    aggregate:
      queryRootField: drugsAggregate
      subscription:
        rootField: drugsAggregate
  description: Danh sách thuốc import từ http://dichvucong.dav.gov.vn/congbothuoc/index

---
kind: ModelPermissions
version: v1
definition:
  modelName: Drugs
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

---
kind: Relationship
version: v1
definition:
  name: drugCategory
  sourceType: Drugs
  target:
    model:
      name: DrugCategories
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: category
      target:
        modelField:
          - fieldName: value

