        - fieldName: registrationCode
          aggregateExpression: TextAggExp
        - fieldName: registrationDecisionCode
          aggregateExpression: TextAggExp
        - fieldName: registrationExpiredAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: registrationExtendedAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: shelfLifeText
          aggregateExpression: TextAggExp
        - fieldName: standard
          aggregateExpression: TextAggExp
        - fieldName: updatedAt
          aggregateExpression: TimestamptzAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: DrugsAggExp

---
kind: OrderByExpression
version: v1
definition:
  name: DrugsOrderByExp
  operand:
    object:
      orderedType: Drugs
      orderableFields:
        - fieldName: activeSubstancesText
          orderByExpression: String1OrderByExp
        - fieldName: brandName
          orderByExpression: String1OrderByExp
        - fieldName: category
          orderByExpression: String1OrderByExp
        - fieldName: concentrationText
