    - name: registrationCode
      type: String_1!
    - name: registrationDecisionCode
      type: String_1
    - name: registrationExpiredAt
      type: Timestamptz
    - name: registrationExtendedAt
      type: Timestamptz
    - name: shelfLifeText
      type: String_1
    - name: standard
      type: String_1
    - name: updatedAt
      type: Timestamptz!
  graphql:
    typeName: Drugs
    inputTypeName: DrugsInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: drugs
      fieldMapping:
        activeSubstancesText:
          column:
            name: active_substances_text
        brandName:
          column:
            name: brand_name
        category:
          column:
            name: category
        concentrationText:
          column:
            name: concentration_text
        createdAt:
          column:
            name: created_at
        form:
          column:
            name: form
        id:
          column:
            name: id
        oldRegistrationCode:
          column:
            name: old_registration_code
        registeredAt:
          column:
            name: registered_at
        registrationCode:
          column:
            name: registration_code
        registrationDecisionCode:
          column:
            name: registration_decision_code
        registrationExpiredAt:
          column:
            name: registration_expired_at
        registrationExtendedAt:
          column:
            name: registration_extended_at
        shelfLifeText:
          column:
            name: shelf_life_text
        standard:
          column:
            name: standard
        updatedAt:
          column:
            name: updated_at

---
kind: TypePermissions
version: v1
definition:
  typeName: Drugs
  permissions:
    - role: admin
      output:
        allowedFields:
          - activeSubstancesText
          - brandName
          - category
          - concentrationText
          - createdAt
          - form
          - id
          - oldRegistrationCode
          - registeredAt
          - registrationCode
          - registrationDecisionCode
          - registrationExpiredAt
          - registrationExtendedAt
          - shelfLifeText
          - standard
          - updatedAt

---
kind: BooleanExpressionType
version: v1
definition:
  name: DrugsBoolExp
  operand:
    object:
      type: Drugs
      comparableFields:
        - fieldName: activeSubstancesText
          booleanExpressionType: TextBoolExp
        - fieldName: brandName
          booleanExpressionType: TextBoolExp
        - fieldName: category
          booleanExpressionType: TextBoolExp
        - fieldName: concentrationText
          booleanExpressionType: TextBoolExp
        - fieldName: createdAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: form
          booleanExpressionType: TextBoolExp
        - fieldName: id
          booleanExpressionType: UuidBoolExp
        - fieldName: oldRegistrationCode
          booleanExpressionType: TextBoolExp
        - fieldName: registeredAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: registrationCode
          booleanExpressionType: TextBoolExp
        - fieldName: registrationDecisionCode
          booleanExpressionType: TextBoolExp
        - fieldName: registrationExpiredAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: registrationExtendedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: shelfLifeText
          booleanExpressionType: TextBoolExp
        - fieldName: standard
          booleanExpressionType: TextBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
      comparableRelationships:
        - relationshipName: drugCategory
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: DrugsBoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: DrugsAggExp
  operand:
    object:
      aggregatedType: Drugs
      aggregatableFields:
        - fieldName: activeSubstancesText
          aggregateExpression: TextAggExp
        - fieldName: brandName
          aggregateExpression: TextAggExp
        - fieldName: category
          aggregateExpression: TextAggExp
        - fieldName: concentrationText
