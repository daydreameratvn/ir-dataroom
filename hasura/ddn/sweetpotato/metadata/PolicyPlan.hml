---
kind: TypePermissions
version: v1
definition:
  typeName: PolicyPlan
  permissions:
    - role: admin
      output:
        allowedFields:
          - cardId
          - createdAt
          - deletedAt
          - enCardId
          - extraPaymentRatio
          - id
          - insuredBenefitTypes
          - jsonDetails
          - planCode
          - planId
          - planName
          - policyId
          - premium
          - tenantId
          - updatedAt

---
kind: BooleanExpressionType
version: v1
definition:
  name: PolicyPlanBoolExp
  operand:
    object:
      type: PolicyPlan
      comparableFields:
        - fieldName: cardId
          booleanExpressionType: UuidBoolExp
        - fieldName: createdAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: deletedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: enCardId
          booleanExpressionType: UuidBoolExp
        - fieldName: extraPaymentRatio
          booleanExpressionType: NumericBoolExp
        - fieldName: id
          booleanExpressionType: UuidBoolExp
        - fieldName: jsonDetails
          booleanExpressionType: JsonbBoolExp
        - fieldName: planCode
          booleanExpressionType: VarcharBoolExp
        - fieldName: planId
          booleanExpressionType: UuidBoolExp
        - fieldName: planName
          booleanExpressionType: TextBoolExp
        - fieldName: policyId
          booleanExpressionType: UuidBoolExp
        - fieldName: premium
          booleanExpressionType: NumericBoolExp
        - fieldName: tenantId
          booleanExpressionType: UuidBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
      comparableRelationships:
        - relationshipName: policiesPlansInsuredBenefits
        - relationshipName: policyFaqs
        - relationshipName: plan
        - relationshipName: policy
        - relationshipName: card
        - relationshipName: cardByEnCardId
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: PolicyPlanBoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: PolicyPlanAggExp
  operand:
    object:
      aggregatedType: PolicyPlan
      aggregatableFields:
        - fieldName: cardId
          aggregateExpression: UuidAggExp
        - fieldName: createdAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: deletedAt
          aggregateExpression: TimestamptzAggExp
        - fieldName: enCardId
