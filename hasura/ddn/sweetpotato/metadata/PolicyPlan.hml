---
kind: Model
version: v2
definition:
  name: PolicyPlan
  objectType: PolicyPlan
  source:
    dataConnectorName: sweetpotato_pg
    collection: policy_plan
  filterExpressionType: PolicyPlanBoolExp
  aggregateExpression: PolicyPlanAggExp
  orderByExpression: PolicyPlanOrderByExp
  graphql:
    selectMany:
      queryRootField: policyPlan
      subscription:
        rootField: policyPlan
    selectUniques:
      - queryRootField: policyPlanByPlanPoliciesPkey
        uniqueIdentifier:
          - planId
          - policyId
        subscription:
          rootField: policyPlanByPlanPoliciesPkey
      - queryRootField: policyPlanByPolicyIdPlanIdDeletedAtKey
        uniqueIdentifier:
          - deletedAt
          - planId
          - policyId
        subscription:
          rootField: policyPlanByPolicyIdPlanIdDeletedAtKey
    filterInputTypeName: PolicyPlanFilterInput
    aggregate:
      queryRootField: policyPlanAggregate
      subscription:
        rootField: policyPlanAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: PolicyPlan
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

