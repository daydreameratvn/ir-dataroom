      fieldMapping:
        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertLanguagesResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

---
kind: Command
version: v1
definition:
  name: InsertLanguages
  outputType: InsertLanguagesResponse!
  arguments:
    - name: objects
      type: "[InsertLanguagesObject!]!"
    - name: postCheck
      type: LanguagesBoolExp
      description: Insert permission predicate over the 'languages' collection
  source:
    dataConnectorName: sweetpotato_pg
    dataConnectorCommand:
      procedure: insert_languages
    argumentMapping:
