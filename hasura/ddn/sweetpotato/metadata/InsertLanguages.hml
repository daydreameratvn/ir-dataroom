          - value

---
kind: ObjectType
version: v1
definition:
  name: InsertLanguagesResponse
  description: Responses from the 'insert_languages' procedure
  fields:
    - name: affectedRows
      type: Int32!
      description: The number of rows affected by the mutation
    - name: returning
      type: "[Languages!]!"
