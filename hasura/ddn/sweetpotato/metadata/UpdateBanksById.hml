      type: UpdateColumnBanksEnName
      description: Update the 'en_name' column in the 'banks' collection.
    - name: id
      type: UpdateColumnBanksId
      description: Update the 'id' column in the 'banks' collection.
    - name: napasSupported
      type: UpdateColumnBanksNapasSupported
      description: Update the 'napas_supported' column in the 'banks' collection.
    - name: shortName
      type: UpdateColumnBanksShortName
      description: Update the 'short_name' column in the 'banks' collection.
    - name: updatedAt
      type: UpdateColumnBanksUpdatedAt
      description: Update the 'updated_at' column in the 'banks' collection.
