    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: update_banks_by_id_update_columns
      fieldMapping:
        bankCode:
          column:
            name: bank_code
        cardLength:
          column:
            name: card_length
        createdAt:
          column:
            name: created_at
        deletedAt:
          column:
            name: deleted_at
        displayOrder:
          column:
            name: display_order
        enName:
          column:
            name: en_name
        id:
          column:
            name: id
        napasSupported:
          column:
            name: napas_supported
        shortName:
          column:
            name: short_name
        updatedAt:
          column:
