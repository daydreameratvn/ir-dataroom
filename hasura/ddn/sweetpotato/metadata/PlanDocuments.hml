  graphql:
    expressionTypeName: PlanDocumentsOrderByExp

---
kind: Model
version: v2
definition:
  name: PlanDocuments
  objectType: PlanDocuments
  source:
    dataConnectorName: sweetpotato_pg
    collection: plan_documents
  filterExpressionType: PlanDocumentsBoolExp
  aggregateExpression: PlanDocumentsAggExp
  orderByExpression: PlanDocumentsOrderByExp
  graphql:
    selectMany:
      queryRootField: planDocuments
      subscription:
        rootField: planDocuments
    selectUniques:
      - queryRootField: planDocumentsByPlanDocumentId
        uniqueIdentifier:
          - planDocumentId
        subscription:
          rootField: planDocumentsByPlanDocumentId
    filterInputTypeName: PlanDocumentsFilterInput
    aggregate:
      queryRootField: planDocumentsAggregate
      subscription:
        rootField: planDocumentsAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: PlanDocuments
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

---
kind: Relationship
version: v1
definition:
  name: files
  sourceType: PlanDocuments
  target:
    model:
      name: Files
      relationshipType: Array
      aggregate:
        aggregateExpression: FilesAggExp
  mapping:
    - source:
        fieldPath:
