  graphql:
    selectTypeName: PlanDocumentsAggExp

---
kind: OrderByExpression
version: v1
definition:
  name: PlanDocumentsOrderByExp
  operand:
    object:
      orderedType: PlanDocuments
      orderableFields:
        - fieldName: createdAt
          orderByExpression: TimestamptzOrderByExp
        - fieldName: deletedAt
          orderByExpression: TimestamptzOrderByExp
        - fieldName: id
