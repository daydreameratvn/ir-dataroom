---
kind: Model
version: v2
definition:
  name: InsuredCertificateHistories
  objectType: InsuredCertificateHistories
  source:
    dataConnectorName: sweetpotato_pg
    collection: insured_certificate_histories
  filterExpressionType: InsuredCertificateHistoriesBoolExp
  aggregateExpression: InsuredCertificateHistoriesAggExp
  orderByExpression: InsuredCertificateHistoriesOrderByExp
  graphql:
    selectMany:
      queryRootField: insuredCertificateHistories
      subscription:
        rootField: insuredCertificateHistories
    selectUniques:
      - queryRootField: insuredCertificateHistoriesById
        uniqueIdentifier:
          - id
        subscription:
          rootField: insuredCertificateHistoriesById
      - queryRootField: insuredCertificateHistoriesByInsuredCertificateHistoriesStartDateInsuredCertificateId
        uniqueIdentifier:
          - insuredCertificateId
          - planId
          - startDate
        subscription:
          rootField: insuredCertificateHistoriesByInsuredCertificateHistoriesStartDateInsuredCertificateId
    filterInputTypeName: InsuredCertificateHistoriesFilterInput
    aggregate:
      queryRootField: insuredCertificateHistoriesAggregate
      subscription:
        rootField: insuredCertificateHistoriesAggregate
  description: Lịch sử thay đổi của insured_certificates

