      type: UpdateColumnCompaniesCcSupportEmailsRefId
      description: Update the 'cc_support_emails_ref_id' column in the 'companies'
        collection.
    - name: claimSubmissionDeadlineInDaysSinceEventDate
      type: UpdateColumnCompaniesClaimSubmissionDeadlineInDaysSinceEventDate
      description: Update the 'claim_submission_deadline_in_days_since_event_date'
        column in the 'companies' collection.
    - name: companyCode
      type: UpdateColumnCompaniesCompanyCode
      description: Update the 'company_code' column in the 'companies' collection.
    - name: companyId
      type: UpdateColumnCompaniesCompanyId
      description: Update the 'company_id' column in the 'companies' collection.
    - name: createdAt
      type: UpdateColumnCompaniesCreatedAt
      description: Update the 'created_at' column in the 'companies' collection.
    - name: createdBy
      type: UpdateColumnCompaniesCreatedBy
      description: Update the 'created_by' column in the 'companies' collection.
    - name: customerSupportEmail
      type: UpdateColumnCompaniesCustomerSupportEmail
      description: Update the 'customer_support_email' column in the 'companies' collection.
    - name: customerSupportPhone
      type: UpdateColumnCompaniesCustomerSupportPhone
      description: Update the 'customer_support_phone' column in the 'companies' collection.
    - name: deletedAt
      type: UpdateColumnCompaniesDeletedAt
      description: Update the 'deleted_at' column in the 'companies' collection.
    - name: description
      type: UpdateColumnCompaniesDescription
      description: Update the 'description' column in the 'companies' collection.
    - name: email
      type: UpdateColumnCompaniesEmail
      description: Update the 'email' column in the 'companies' collection.
    - name: emailDomain
      type: UpdateColumnCompaniesEmailDomain
      description: Update the 'email_domain' column in the 'companies' collection.
    - name: faqUrl
      type: UpdateColumnCompaniesFaqUrl
      description: Update the 'faq_url' column in the 'companies' collection.
    - name: isMainTpa
      type: UpdateColumnCompaniesIsMainTpa
      description: Update the 'is_main_tpa' column in the 'companies' collection.
    - name: logo
      type: UpdateColumnCompaniesLogo
      description: Update the 'logo' column in the 'companies' collection.
    - name: logoUrl
      type: UpdateColumnCompaniesLogoUrl
      description: Update the 'logo_url' column in the 'companies' collection.
    - name: name
      type: UpdateColumnCompaniesName
      description: Update the 'name' column in the 'companies' collection.
