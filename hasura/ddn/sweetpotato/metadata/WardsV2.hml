  graphql:
    expressionTypeName: WardsV2OrderByExp

---
kind: Model
version: v2
definition:
  name: WardsV2
  objectType: WardsV2
  source:
    dataConnectorName: sweetpotato_pg
    collection: wards_v2
  filterExpressionType: WardsV2BoolExp
  aggregateExpression: WardsV2AggExp
  orderByExpression: WardsV2OrderByExp
  graphql:
    selectMany:
