      dataConnectorObjectType: wards_v2
      fieldMapping:
        code:
          column:
            name: code
        id:
          column:
            name: id
        name:
          column:
            name: name
        provinceId:
          column:
            name: province_id

---
kind: TypePermissions
version: v1
definition:
  typeName: WardsV2
  permissions:
    - role: admin
      output:
        allowedFields:
          - code
          - id
          - name
          - provinceId

---
kind: BooleanExpressionType
version: v1
definition:
  name: WardsV2BoolExp
  operand:
    object:
      type: WardsV2
      comparableFields:
        - fieldName: code
          booleanExpressionType: TextBoolExp
        - fieldName: id
          booleanExpressionType: NumericBoolExp
        - fieldName: name
          booleanExpressionType: TextBoolExp
        - fieldName: provinceId
          booleanExpressionType: NumericBoolExp
      comparableRelationships:
        - relationshipName: mpMedicalProviders
        - relationshipName: province
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: WardsV2BoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: WardsV2AggExp
  operand:
    object:
      aggregatedType: WardsV2
      aggregatableFields:
        - fieldName: code
          aggregateExpression: TextAggExp
        - fieldName: id
          aggregateExpression: NumericAggExp
        - fieldName: name
          aggregateExpression: TextAggExp
        - fieldName: provinceId
          aggregateExpression: NumericAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: WardsV2AggExp

---
kind: OrderByExpression
version: v1
definition:
  name: WardsV2OrderByExp
  operand:
    object:
      orderedType: WardsV2
      orderableFields:
        - fieldName: code
          orderByExpression: String1OrderByExp
        - fieldName: id
          orderByExpression: BigdecimalOrderByExp
        - fieldName: name
          orderByExpression: String1OrderByExp
        - fieldName: provinceId
