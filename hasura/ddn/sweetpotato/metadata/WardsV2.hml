---
kind: ObjectType
version: v1
definition:
  name: WardsV2
  fields:
    - name: code
      type: String_1!
    - name: id
      type: Bigdecimal!
    - name: name
      type: String_1!
    - name: provinceId
      type: Bigdecimal!
  graphql:
    typeName: WardsV2
    inputTypeName: WardsV2Input
  dataConnectorTypeMapping:
