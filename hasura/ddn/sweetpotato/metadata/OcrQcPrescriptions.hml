---
kind: Model
version: v2
definition:
  name: OcrQcPrescriptions
  objectType: OcrQcPrescriptions
  source:
    dataConnectorName: sweetpotato_pg
    collection: ocr_qc_prescriptions
  filterExpressionType: OcrQcPrescriptionsBoolExp
  aggregateExpression: OcrQcPrescriptionsAggExp
  orderByExpression: OcrQcPrescriptionsOrderByExp
  graphql:
    selectMany:
      queryRootField: ocrQcPrescriptions
      subscription:
        rootField: ocrQcPrescriptions
    selectUniques:
      - queryRootField: ocrQcPrescriptionsByPaperId
        uniqueIdentifier:
          - paperId
        subscription:
          rootField: ocrQcPrescriptionsByPaperId
      - queryRootField: ocrQcPrescriptionsById
        uniqueIdentifier:
          - id
        subscription:
          rootField: ocrQcPrescriptionsById
    filterInputTypeName: OcrQcPrescriptionsFilterInput
    aggregate:
      queryRootField: ocrQcPrescriptionsAggregate
      subscription:
        rootField: ocrQcPrescriptionsAggregate

