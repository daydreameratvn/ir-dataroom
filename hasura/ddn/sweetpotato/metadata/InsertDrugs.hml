---
kind: TypePermissions
version: v1
definition:
  typeName: InsertDrugsObject
  permissions:
    - role: admin
      output:
        allowedFields:
          - activeSubstancesText
          - brandName
          - category
          - concentrationText
          - createdAt
          - form
          - id
          - oldRegistrationCode
          - registeredAt
          - registrationCode
          - registrationDecisionCode
          - registrationExpiredAt
          - registrationExtendedAt
          - shelfLifeText
          - standard
          - updatedAt

---
kind: ObjectType
version: v1
definition:
  name: InsertDrugsResponse
  description: Responses from the 'insert_drugs' procedure
  fields:
    - name: affectedRows
      type: Int32!
      description: The number of rows affected by the mutation
    - name: returning
      type: "[Drugs!]!"
      description: Data from rows affected by the mutation
  graphql:
    typeName: InsertDrugsResponse
    inputTypeName: InsertDrugsResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: insert_drugs_response
      fieldMapping:
        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertDrugsResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

---
kind: Command
version: v1
definition:
  name: InsertDrugs
  outputType: InsertDrugsResponse!
  arguments:
    - name: objects
      type: "[InsertDrugsObject!]!"
    - name: postCheck
      type: DrugsBoolExp
      description: Insert permission predicate over the 'drugs' collection
  source:
    dataConnectorName: sweetpotato_pg
    dataConnectorCommand:
      procedure: insert_drugs
    argumentMapping:
      objects: objects
      postCheck: post_check
  graphql:
    rootFieldName: insertDrugs
    rootFieldKind: Mutation
  description: Insert into the drugs table

---
kind: CommandPermissions
version: v1
definition:
  commandName: InsertDrugs
  permissions:
    - role: admin
      allowExecution: true

