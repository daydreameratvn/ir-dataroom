---
kind: Model
version: v2
definition:
  name: InsuredCertificates
  objectType: InsuredCertificates
  source:
    dataConnectorName: sweetpotato_pg
    collection: insured_certificates
  filterExpressionType: InsuredCertificatesBoolExp
  aggregateExpression: InsuredCertificatesAggExp
  orderByExpression: InsuredCertificatesOrderByExp
  graphql:
    selectMany:
      queryRootField: insuredCertificates
      subscription:
        rootField: insuredCertificates
    selectUniques:
      - queryRootField: insuredCertificatesByInsuredCertificatesCertificateCodeKey
        uniqueIdentifier:
          - certificateCode
          - deletedAt
        subscription:
          rootField: insuredCertificatesByInsuredCertificatesCertificateCodeKey
      - queryRootField: insuredCertificatesByInsuredCertificateId
        uniqueIdentifier:
          - insuredCertificateId
        subscription:
          rootField: insuredCertificatesByInsuredCertificateId
    filterInputTypeName: InsuredCertificatesFilterInput
    aggregate:
      queryRootField: insuredCertificatesAggregate
      subscription:
        rootField: insuredCertificatesAggregate
  description: Thẻ của người được bảo hiểm

