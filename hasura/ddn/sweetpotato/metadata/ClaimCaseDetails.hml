---
kind: Model
version: v2
definition:
  name: ClaimCaseDetails
  objectType: ClaimCaseDetails
  source:
    dataConnectorName: sweetpotato_pg
    collection: claim_case_details
  filterExpressionType: ClaimCaseDetailsBoolExp
  aggregateExpression: ClaimCaseDetailsAggExp
  orderByExpression: ClaimCaseDetailsOrderByExp
  graphql:
    selectMany:
      queryRootField: claimCaseDetails
      subscription:
        rootField: claimCaseDetails
    selectUniques:
      - queryRootField: claimCaseDetailsByClaimCaseDetailsPlanInsuredBenefitIdClaimCaseIdInsure
        uniqueIdentifier:
          - claimCaseId
          - deletedAt
          - gracePeriodStartDate
          - insuredCertificateHistoryId
          - planInsuredBenefitId
        subscription:
          rootField: claimCaseDetailsByClaimCaseDetailsPlanInsuredBenefitIdClaimCaseIdInsure
      - queryRootField: claimCaseDetailsByClaimCaseDetailId
        uniqueIdentifier:
          - claimCaseDetailId
        subscription:
          rootField: claimCaseDetailsByClaimCaseDetailId
    filterInputTypeName: ClaimCaseDetailsFilterInput
    aggregate:
      queryRootField: claimCaseDetailsAggregate
      subscription:
        rootField: claimCaseDetailsAggregate
  description: Chi tiết bồi thường được thẩm định theo quyền lợi

