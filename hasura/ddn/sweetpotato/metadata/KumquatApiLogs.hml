      description: Decrypted request payload for debugging
    - name: requestBodyEncrypted
      type: Json
      description: Original encrypted request envelope as received
    - name: requestId
      type: String_1!
      description: Unique trace ID for correlating logs across services
    - name: responseBody
      type: Json
      description: Response data before encryption
    - name: responseStatus
      type: Int32!
    - name: serviceVersion
      type: String_1
    - name: startedAt
      type: Timestamptz!
    - name: userAgent
      type: String_1
