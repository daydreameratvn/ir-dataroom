        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertPolicySettingsResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

