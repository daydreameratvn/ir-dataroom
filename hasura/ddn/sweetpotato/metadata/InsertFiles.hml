    - name: tenantId
      type: Uuid
    - name: updatedAt
      type: Timestamptz
    - name: updatedBy
      type: Uuid
    - name: url
      type: String_1
    - name: urlExpiredAt
      type: Timestamptz
    - name: userId
      type: Uuid
    - name: userName
      type: String_1
  graphql:
    typeName: InsertFilesObject
    inputTypeName: InsertFilesObjectInput
  dataConnectorTypeMapping:
