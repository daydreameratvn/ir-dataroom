        deletedAt:
          column:
            name: deleted_at
        executionArn:
          column:
            name: execution_arn
        fileId:
          column:
            name: file_id
        hash:
          column:
            name: hash
        isRotated:
          column:
            name: is_rotated
        medicalProviderId:
          column:
            name: medical_provider_id
        mimeType:
          column:
            name: mime_type
        name:
          column:
            name: name
        originalFileId:
          column:
            name: original_file_id
        overlordDocumentId:
          column:
            name: overlord_document_id
        pageNumber:
          column:
