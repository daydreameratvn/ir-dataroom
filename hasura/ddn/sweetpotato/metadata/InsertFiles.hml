          column:
            name: processed_v2
        rawOcrData:
          column:
            name: raw_ocr_data
        tenantId:
          column:
            name: tenant_id
        updatedAt:
          column:
            name: updated_at
        updatedBy:
          column:
            name: updated_by
        url:
          column:
            name: url
        urlExpiredAt:
          column:
            name: url_expired_at
        userId:
          column:
            name: user_id
        userName:
          column:
            name: user_name

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertFilesObject
  permissions:
    - role: admin
      output:
        allowedFields:
          - authenticFileId
          - autoRotateResult
          - bucketName
          - bucketNameV2
          - bucketObjectKey
          - cardId
          - claimDocumentId
          - companyId
          - correspondenceHistoryId
          - createdAt
          - createdBy
          - deletedAt
          - executionArn
          - fileId
          - hash
          - isRotated
          - medicalProviderId
          - mimeType
          - name
          - originalFileId
          - overlordDocumentId
          - pageNumber
          - payoutTransactionId
          - planDocumentId
          - policyDocumentId
          - processedV2
          - rawOcrData
          - tenantId
          - updatedAt
          - updatedBy
          - url
          - urlExpiredAt
          - userId
          - userName

---
kind: ObjectType
version: v1
definition:
  name: InsertFilesResponse
  description: Responses from the 'insert_files' procedure
  fields:
    - name: affectedRows
      type: Int32!
      description: The number of rows affected by the mutation
    - name: returning
      type: "[Files!]!"
      description: Data from rows affected by the mutation
  graphql:
    typeName: InsertFilesResponse
    inputTypeName: InsertFilesResponseInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: insert_files_response
      fieldMapping:
        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: InsertFilesResponse
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

---
kind: Command
version: v1
definition:
  name: InsertFiles
  outputType: InsertFilesResponse!
  arguments:
    - name: objects
      type: "[InsertFilesObject!]!"
    - name: postCheck
      type: FilesBoolExp
      description: Insert permission predicate over the 'files' collection
  source:
    dataConnectorName: sweetpotato_pg
    dataConnectorCommand:
      procedure: insert_files
    argumentMapping:
      objects: objects
      postCheck: post_check
  graphql:
    rootFieldName: insertFiles
    rootFieldKind: Mutation
  description: Insert into the files table

---
kind: CommandPermissions
version: v1
definition:
  commandName: InsertFiles
  permissions:
    - role: admin
      allowExecution: true

