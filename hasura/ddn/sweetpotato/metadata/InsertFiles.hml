---
kind: ObjectType
version: v1
definition:
  name: InsertFilesObject
  fields:
    - name: authenticFileId
      type: Uuid
    - name: autoRotateResult
      type: Json
    - name: bucketName
      type: String_1!
      description: "deprecated: use bucket_name_v2 for correct data"
    - name: bucketNameV2
      type: String_1
    - name: bucketObjectKey
      type: String_1
    - name: cardId
      type: Uuid
    - name: claimDocumentId
      type: Uuid
    - name: companyId
      type: Uuid
    - name: correspondenceHistoryId
      type: Uuid
    - name: createdAt
      type: Timestamptz
    - name: createdBy
      type: Uuid
    - name: deletedAt
      type: Timestamptz
    - name: executionArn
      type: String_1
    - name: fileId
      type: Uuid
    - name: hash
      type: String_1
    - name: isRotated
      type: Boolean_1
    - name: medicalProviderId
      type: Uuid
    - name: mimeType
      type: String_1!
    - name: name
      type: String_1!
      description: "deprecated: use bucket_object_key"
    - name: originalFileId
      type: Uuid
      description: could be pdf file before splitted or image before resized
    - name: overlordDocumentId
      type: Uuid
    - name: pageNumber
      type: Int32
    - name: payoutTransactionId
      type: Uuid
    - name: planDocumentId
      type: Uuid
    - name: policyDocumentId
      type: Uuid
    - name: processedV2
      type: Boolean_1
