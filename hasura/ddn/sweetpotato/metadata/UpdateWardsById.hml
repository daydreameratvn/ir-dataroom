    - name: id
      type: UpdateColumnWardsId
      description: Update the 'id' column in the 'wards' collection.
    - name: name
      type: UpdateColumnWardsName
      description: Update the 'name' column in the 'wards' collection.
    - name: prefix
      type: UpdateColumnWardsPrefix
      description: Update the 'prefix' column in the 'wards' collection.
  graphql:
    typeName: UpdateWardsByIdUpdateColumns
    inputTypeName: UpdateWardsByIdUpdateColumnsInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: update_wards_by_id_update_columns
      fieldMapping:
        cityId:
          column:
            name: city_id
        displayOrder:
          column:
