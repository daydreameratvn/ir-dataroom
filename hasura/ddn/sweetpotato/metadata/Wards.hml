---
kind: ObjectType
version: v1
definition:
  name: Wards
  fields:
    - name: cityId
      type: Int32!
    - name: displayOrder
      type: Int32
    - name: districtId
      type: Int32!
    - name: fullName
      type: String_1
    - name: id
      type: Int32!
    - name: name
      type: String_1!
    - name: prefix
      type: String_1
  graphql:
    typeName: Wards
    inputTypeName: WardsInput
  dataConnectorTypeMapping:
    - dataConnectorName: sweetpotato_pg
      dataConnectorObjectType: wards
      fieldMapping:
        cityId:
          column:
            name: city_id
        displayOrder:
          column:
            name: display_order
        districtId:
          column:
            name: district_id
        fullName:
          column:
            name: full_name
        id:
          column:
            name: id
        name:
          column:
            name: name
        prefix:
          column:
            name: prefix

---
kind: TypePermissions
version: v1
definition:
  typeName: Wards
  permissions:
    - role: admin
      output:
        allowedFields:
          - cityId
          - displayOrder
          - districtId
          - fullName
          - id
          - name
          - prefix

---
kind: BooleanExpressionType
version: v1
definition:
  name: WardsBoolExp
  operand:
    object:
      type: Wards
      comparableFields:
        - fieldName: cityId
          booleanExpressionType: Int4BoolExp
        - fieldName: displayOrder
          booleanExpressionType: Int4BoolExp
        - fieldName: districtId
          booleanExpressionType: Int4BoolExp
        - fieldName: fullName
          booleanExpressionType: VarcharBoolExp
        - fieldName: id
          booleanExpressionType: Int4BoolExp
        - fieldName: name
          booleanExpressionType: VarcharBoolExp
        - fieldName: prefix
          booleanExpressionType: VarcharBoolExp
      comparableRelationships:
        - relationshipName: mpMedicalProviders
        - relationshipName: city
        - relationshipName: district
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: WardsBoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: WardsAggExp
  operand:
    object:
      aggregatedType: Wards
      aggregatableFields:
        - fieldName: cityId
          aggregateExpression: Int4AggExp
        - fieldName: displayOrder
          aggregateExpression: Int4AggExp
        - fieldName: districtId
          aggregateExpression: Int4AggExp
        - fieldName: fullName
          aggregateExpression: VarcharAggExp
        - fieldName: id
          aggregateExpression: Int4AggExp
        - fieldName: name
          aggregateExpression: VarcharAggExp
        - fieldName: prefix
          aggregateExpression: VarcharAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: WardsAggExp

---
kind: OrderByExpression
version: v1
definition:
  name: WardsOrderByExp
  operand:
    object:
      orderedType: Wards
      orderableFields:
        - fieldName: cityId
          orderByExpression: Int32OrderByExp
        - fieldName: displayOrder
          orderByExpression: Int32OrderByExp
        - fieldName: districtId
          orderByExpression: Int32OrderByExp
        - fieldName: fullName
          orderByExpression: String1OrderByExp
        - fieldName: id
          orderByExpression: Int32OrderByExp
        - fieldName: name
          orderByExpression: String1OrderByExp
        - fieldName: prefix
          orderByExpression: String1OrderByExp
      orderableRelationships:
        - relationshipName: city
        - relationshipName: district
  graphql:
    expressionTypeName: WardsOrderByExp

---
kind: Model
version: v2
definition:
  name: Wards
  objectType: Wards
  source:
    dataConnectorName: sweetpotato_pg
    collection: wards
  filterExpressionType: WardsBoolExp
  aggregateExpression: WardsAggExp
  orderByExpression: WardsOrderByExp
  graphql:
    selectMany:
      queryRootField: wards
      subscription:
        rootField: wards
    selectUniques:
      - queryRootField: wardsById
        uniqueIdentifier:
          - id
        subscription:
          rootField: wardsById
    filterInputTypeName: WardsFilterInput
    aggregate:
      queryRootField: wardsAggregate
      subscription:
        rootField: wardsAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: Wards
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

---
kind: Relationship
version: v1
definition:
  name: mpMedicalProviders
  sourceType: Wards
  target:
    model:
      name: MpMedicalProviders
      relationshipType: Array
      aggregate:
        aggregateExpression: MpMedicalProvidersAggExp
  mapping:
    - source:
        fieldPath:
          - fieldName: id
      target:
        modelField:
          - fieldName: wardId
  graphql:
    aggregateFieldName: mpMedicalProvidersAggregate

---
kind: Relationship
version: v1
definition:
  name: city
  sourceType: Wards
  target:
    model:
      name: Cities
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: cityId
      target:
        modelField:
          - fieldName: id

---
kind: Relationship
version: v1
definition:
  name: district
  sourceType: Wards
  target:
    model:
      name: Districts
      relationshipType: Object
  mapping:
    - source:
        fieldPath:
          - fieldName: districtId
      target:
        modelField:
          - fieldName: id

