---
kind: Model
version: v2
definition:
  name: ClaimCases
  objectType: ClaimCases
  source:
    dataConnectorName: sweetpotato_pg
    collection: claim_cases
  filterExpressionType: ClaimCasesBoolExp
  aggregateExpression: ClaimCasesAggExp
  orderByExpression: ClaimCasesOrderByExp
  graphql:
    selectMany:
      queryRootField: claimCases
      subscription:
        rootField: claimCases
    selectUniques:
      - queryRootField: claimCasesByClaimCaseId
        uniqueIdentifier:
          - claimCaseId
        subscription:
          rootField: claimCasesByClaimCaseId
      - queryRootField: claimCasesByCodeDeletedAtKey
        uniqueIdentifier:
          - code
          - deletedAt
        subscription:
          rootField: claimCasesByCodeDeletedAtKey
    filterInputTypeName: ClaimCasesFilterInput
    aggregate:
      queryRootField: claimCasesAggregate
      subscription:
        rootField: claimCasesAggregate
  description: Hồ sơ bồi thường

