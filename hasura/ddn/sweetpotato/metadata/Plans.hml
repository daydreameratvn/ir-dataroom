---
kind: Model
version: v2
definition:
  name: Plans
  objectType: Plans
  source:
    dataConnectorName: sweetpotato_pg
    collection: plans
  filterExpressionType: PlansBoolExp
  aggregateExpression: PlansAggExp
  orderByExpression: PlansOrderByExp
  graphql:
    selectMany:
      queryRootField: plans
      subscription:
        rootField: plans
    selectUniques:
      - queryRootField: plansByCode
        uniqueIdentifier:
          - code
        subscription:
          rootField: plansByCode
      - queryRootField: plansByPlanId
        uniqueIdentifier:
          - planId
        subscription:
          rootField: plansByPlanId
    filterInputTypeName: PlansFilterInput
    aggregate:
      queryRootField: plansAggregate
      subscription:
        rootField: plansAggregate

