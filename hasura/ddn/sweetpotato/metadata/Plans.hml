          booleanExpressionType: TextBoolExp
        - fieldName: tenantId
          booleanExpressionType: UuidBoolExp
        - fieldName: terms
          booleanExpressionType: TextBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: updatedBy
          booleanExpressionType: UuidBoolExp
      comparableRelationships:
        - relationshipName: companyCorrespondences
        - relationshipName: displayedCopays
        - relationshipName: insuredCertificateHistories
        - relationshipName: insuredCertificates
        - relationshipName: planBalances
        - relationshipName: planCoPayments
        - relationshipName: planDetails
        - relationshipName: planDisplayedBalances
