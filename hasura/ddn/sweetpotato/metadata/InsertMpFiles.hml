---
kind: Command
version: v1
definition:
  name: InsertMpFiles
  outputType: InsertMpFilesResponse!
  arguments:
    - name: objects
      type: "[InsertMpFilesObject!]!"
    - name: postCheck
      type: MpFilesBoolExp
      description: Insert permission predicate over the 'mp_files' collection
  source:
