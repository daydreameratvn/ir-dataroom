---
kind: Model
version: v2
definition:
  name: Files
  objectType: Files
  source:
    dataConnectorName: sweetpotato_pg
    collection: files
  filterExpressionType: FilesBoolExp
  aggregateExpression: FilesAggExp
  orderByExpression: FilesOrderByExp
  graphql:
    selectMany:
      queryRootField: files
      subscription:
        rootField: files
    selectUniques:
      - queryRootField: filesByCardId
        uniqueIdentifier:
          - cardId
        subscription:
          rootField: filesByCardId
      - queryRootField: filesByClaimDocumentId
        uniqueIdentifier:
          - claimDocumentId
        subscription:
          rootField: filesByClaimDocumentId
      - queryRootField: filesByCompanyId
        uniqueIdentifier:
          - companyId
        subscription:
          rootField: filesByCompanyId
      - queryRootField: filesByFileId
        uniqueIdentifier:
          - fileId
        subscription:
          rootField: filesByFileId
      - queryRootField: filesByPlanDocumentId
        uniqueIdentifier:
          - planDocumentId
        subscription:
          rootField: filesByPlanDocumentId
      - queryRootField: filesByPolicyDocumentId
        uniqueIdentifier:
          - policyDocumentId
        subscription:
          rootField: filesByPolicyDocumentId
    filterInputTypeName: FilesFilterInput
    aggregate:
      queryRootField: filesAggregate
      subscription:
        rootField: filesAggregate

