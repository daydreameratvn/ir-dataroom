        - fieldName: deletedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: executionArn
          booleanExpressionType: TextBoolExp
        - fieldName: fileId
          booleanExpressionType: UuidBoolExp
        - fieldName: hasOcrRawData
          booleanExpressionType: BoolBoolExp
        - fieldName: hash
          booleanExpressionType: TextBoolExp
        - fieldName: id
          booleanExpressionType: UuidBoolExp
        - fieldName: isRotated
          booleanExpressionType: BoolBoolExp
        - fieldName: medicalProviderId
          booleanExpressionType: UuidBoolExp
        - fieldName: mimeType
          booleanExpressionType: VarcharBoolExp
        - fieldName: name
          booleanExpressionType: VarcharBoolExp
        - fieldName: originalFileId
          booleanExpressionType: UuidBoolExp
        - fieldName: overlordDocumentId
          booleanExpressionType: UuidBoolExp
        - fieldName: pageNumber
          booleanExpressionType: Int4BoolExp
        - fieldName: payoutTransactionId
          booleanExpressionType: UuidBoolExp
        - fieldName: planDocumentId
          booleanExpressionType: UuidBoolExp
        - fieldName: policyDocumentId
          booleanExpressionType: UuidBoolExp
        - fieldName: processedV2
          booleanExpressionType: BoolBoolExp
        - fieldName: rawOcrData
          booleanExpressionType: JsonbBoolExp
        - fieldName: tenantId
          booleanExpressionType: UuidBoolExp
        - fieldName: updatedAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: updatedBy
          booleanExpressionType: UuidBoolExp
        - fieldName: url
          booleanExpressionType: TextBoolExp
        - fieldName: urlExpiredAt
          booleanExpressionType: TimestamptzBoolExp
        - fieldName: userId
          booleanExpressionType: UuidBoolExp
        - fieldName: userName
          booleanExpressionType: TextBoolExp
      comparableRelationships:
        - relationshipName: correspondenceEmailAttachments
        - relationshipName: file
        - relationshipName: files
        - relationshipName: card
        - relationshipName: claimDocument
        - relationshipName: correspondenceHistory
        - relationshipName: identityUser
        - relationshipName: overlordDocument
        - relationshipName: fileByOriginalFileId
        - relationshipName: filesByOriginalFileId
        - relationshipName: payoutTransaction
        - relationshipName: planDocument
        - relationshipName: policyDocument
        - relationshipName: tenant
        - relationshipName: fwdClaimDocumentSyncHistories
        - relationshipName: fwdSyncDocuments
        - relationshipName: fwdSyncLogs
        - relationshipName: hawthornDocuments
        - relationshipName: hazelnutDocuments
        - relationshipName: importedFiles
        - relationshipName: insuredPersons
        - relationshipName: mpMedicalProviderDocuments
        - relationshipName: reports
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: FilesBoolExp

