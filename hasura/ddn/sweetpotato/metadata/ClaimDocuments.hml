      dataConnectorObjectType: claim_documents
      fieldMapping:
        assessedClaimPendingCodeIds:
          column:
            name: assessed_claim_pending_code_ids
        claimCaseId:
          column:
            name: claim_case_id
        claimDocumentId:
          column:
            name: claim_document_id
        claimPendingCodeId:
          column:
            name: claim_pending_code_id
        createdAt:
          column:
            name: created_at
        deletedAt:
          column:
            name: deleted_at
        deletedBy:
          column:
            name: deleted_by
        displayOrder:
          column:
