    - name: tenantId
      type: Uuid!
    - name: type
      type: String_1!
    - name: updatedAt
      type: Timestamptz!
    - name: uploaderId
      type: Uuid
    - name: userName
      type: String_1
    - name: userRoleId
      type: Uuid
  graphql:
    typeName: ClaimDocuments_1
    inputTypeName: ClaimDocumentsInput_1
  dataConnectorTypeMapping:
