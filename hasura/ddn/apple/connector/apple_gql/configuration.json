{
  "$schema": "configuration.schema.json",
  "introspection": {
    "endpoint": {
      "valueFromEnv": "GRAPHQL_ENDPOINT"
    },
    "headers": {
      "x-hasura-admin-secret": {
        "valueFromEnv": "GRAPHQL_ADMIN_SECRET"
      }
    }
  },
  "execution": {
    "endpoint": {
      "valueFromEnv": "GRAPHQL_ENDPOINT"
    },
    "headers": {
      "x-hasura-admin-secret": {
        "valueFromEnv": "GRAPHQL_ADMIN_SECRET"
      }
    }
  },
  "request": {
    "forwardHeaders": [
      "X-Hasura-*",
      "Authorization"
    ]
  }
}